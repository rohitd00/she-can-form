# Copy this file to .env and fill in your values

# SQLite database file path (relative to the prisma/ directory)
# The .db file is created automatically on first migration — no server needed
DATABASE_URL="file:./shecan.db"

# JWT secret — use a long random string in production
# Generate one via: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change_this_to_something_very_random_and_long_at_least_32_chars"

# Token expiry (e.g. 1h, 12h, 7d)
JWT_EXPIRES_IN="12h"

# Server port
PORT=5000

# Allowed frontend origin for CORS
# Use "http://localhost:3000" for a dev server, or your production URL.
# The backend also accepts file:// origins automatically for local development.
CLIENT_ORIGIN="http://localhost:3000"

# admin
# admin@shecan123
# Admin credentials for seeding (used only by: npm run seed)
# Never commit real values — keep this file as .env.example only
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change_this_to_a_strong_password_before_seeding"
