// This is the Prisma schema for She Can Foundation's contact form system.
// It handles storing form submissions and admin user accounts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Submission {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")
  isRead    Boolean  @default(false) @map("is_read")

  @@map("submissions")
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admins")
}
